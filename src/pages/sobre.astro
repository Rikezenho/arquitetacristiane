---
import Layout from "../layouts/Layout.astro";
import about from "../content/settings/about.json";
import { marked } from "marked";

const contentHtml = marked.parse(about.content);
---

<Layout
  title={about.title + " | Cristiane David"}
  description={about.description}
>
  <section class="container mx-auto px-4 py-20 relative z-20">
    <h1 class="text-4xl md:text-5xl text-left mb-10 text-primary-600">
      {about.title}
    </h1>
    <article class="flex flex-col lg:flex-row gap-4 lg:gap-10">
      {
        about.photo && (
          <div class="about-photo lg:min-w-[400px] xl:min-w-[600px] max-w-sm">
            <img src={about.photo} alt={about.title} class="mb-4" />
          </div>
        )
      }
      <div
        class="prose max-w-none text-gray-700 flex flex-col gap-6 text-balanc"
        set:html={contentHtml}
      />
    </article>
  </section>
</Layout>

---
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(project => project.data.featured)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<section class="container mx-auto px-4 py-20">
  <div class="text-center mb-12">
    <h2 class="text-4xl md:text-5xl font-display mb-4 text-tertiary-700">Projetos em Destaque</h2>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto">
      Conheça alguns dos nossos trabalhos mais recentes e inspiradores
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
    {featuredProjects.map((project) => (
      <article class="group overflow-hidden rounded-lg shadow-lg hover:shadow-2xl transition-all duration-300">
        <a href={`/projetos/${project.slug}`}>
          <div class="aspect-[4/3] overflow-hidden bg-gray-200">
            {project.data.image && (
              <img 
                src={project.data.image} 
                alt={project.data.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              />
            )}
          </div>
          <div class="p-6 bg-white">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs bg-primary-100 text-primary-700 px-3 py-1 rounded-full font-medium">
                {project.data.category}
              </span>
              <time class="text-sm text-gray-500">
                {new Date(project.data.date).toLocaleDateString('pt-BR', { year: 'numeric' })}
              </time>
            </div>
            <h3 class="text-2xl font-semibold mb-2 group-hover:text-primary-600 transition-colors">
              {project.data.title}
            </h3>
            <p class="text-gray-600 line-clamp-3">{project.data.description}</p>
          </div>
        </a>
      </article>
    ))}
  </div>

  <div class="text-center">
    <a 
      href="/projetos" 
      class="inline-flex items-center px-8 py-4 bg-tertiary-400 text-white rounded-lg hover:bg-tertiary-600 transition-colors font-semibold shadow-lg"
    >
      Ver Todos os Projetos
      <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
  </div>
</section>

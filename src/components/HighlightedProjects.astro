---
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((project) => project.data.featured)
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  )
  .slice(0, 3);
---

<section class="py-20 px-4">
  <div class="text-center mb-12">
    <h2 class="text-4xl md:text-5xl font-display mb-4 text-tertiary-700">
      Projetos em Destaque
    </h2>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto">
      Conheça alguns dos nossos trabalhos mais recentes e inspiradores
    </p>
  </div>

  <div class="max-w-2xl mx-auto flex flex-col gap-4 mb-12">
    {
      featuredProjects.map((project) => (
        <article class="group relative overflow-hidden rounded-lg shadow-md hover:shadow-xl transition-shadow duration-300">
          <a href={`/projetos/${project.slug}`} class="block">
            <div class="aspect-[4/3] overflow-hidden bg-gray-200">
              {project.data.image && (
                <img
                  src={project.data.image}
                  alt={project.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              )}
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent" />
            <div class="absolute bottom-0 left-0 right-0 flex items-end justify-between px-5 py-4">
              <div>
                <span class="inline-block text-xs bg-tertiary-400/90 text-white px-3 py-1 rounded-full font-medium mb-2">
                  {project.data.category}
                </span>
                <h3 class="text-lg font-semibold text-white drop-shadow-sm">
                  {project.data.title}
                </h3>
              </div>
              <div class="shrink-0 ml-4 w-9 h-9 flex items-center justify-center rounded-md bg-tertiary-400/90 text-white group-hover:bg-tertiary-500 transition-colors">
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"
                  />
                </svg>
              </div>
            </div>
          </a>
        </article>
      ))
    }
  </div>

  <div class="text-center">
    <a
      href="/projetos"
      class="inline-flex items-center px-8 py-4 bg-tertiary-400 text-white rounded-lg hover:bg-tertiary-600 transition-colors font-semibold shadow-lg"
    >
      Ver Todos os Projetos
      <svg
        class="w-5 h-5 ml-2"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
  </div>
</section>

---
import { getCollection } from "astro:content";

const allServices = await getCollection("services");
const sortedServices = allServices.sort((a, b) => a.data.order - b.data.order);
---

<section id="servicos" class="bg-gray-50 py-20">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-display text-tertiary-700 mb-4">
        Serviços
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Soluções completas em arquitetura de interiores para transformar seus
        espaços
      </p>
    </div>

    <div class="flex gap-4 flex-col lg:flex-row">
      {
        sortedServices.map((service) => (
          <div class="bg-white p-8 rounded-lg hover:shadow-xl transition-shadow flex flex-col justify-between">
            <div class="flex flex-col mb-6">
              <div class="w-16 h-16 rounded-lg flex items-center justify-center mb-4">
                <img src={`/${service.data.icon}.svg`} alt={service.data.title} class="w-16 h-16" />
              </div>
              <h3 class="text-2xl font-semibold text-tertiary-700">
                {service.data.title}
              </h3>
            </div>
            <p class="text-gray-600 mb-4">{service.data.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
